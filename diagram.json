{
  "version": 1,
  "author": "you",
  "editor": "wokwi",
  "parts": [
    { "type": "wokwi-esp32-devkit-v1", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    { "type": "board-ssd1306", "id": "oled1", "top": -100, "left": 220, "attrs": { "i2cAddress": "0x3c" } },
    { "type": "wokwi-pushbutton", "id": "btn1", "top": 120, "left": 220, "attrs": {} }
  ],
  "connections": [
  [ "esp:TX0", "$serialMonitor:RX", "", [] ],
  [ "esp:RX0", "$serialMonitor:TX", "", [] ],

  [ "esp:3V3", "oled1:VCC", "red", [] ],
  [ "oled1:GND", "esp:GND.1", "black", [] ],
  [ "oled1:SDA", "esp:D21", "green", [] ],
  [ "oled1:SCL", "esp:D22", "blue", [] ],

  [ "btn1:1.l", "esp:D18", "green", [] ],
  [ "btn1:2.l", "esp:GND.1", "black", [] ]
],
  

  "serialMonitor": {
    "display": "terminal",
    "newline": "lf",
    "convertEol": true
    },

    "dependencies": {}
}